# ─────────────────────────────────────────────────────────────────────────
# Required — the API exits at boot if any of these are missing.
# ─────────────────────────────────────────────────────────────────────────

# SQLite database file. Relative paths resolve from packages/api (where the API
# process runs in local dev), so this points at <repo>/data/app.db.
# docker-compose overrides this to /data/app.db (the mounted volume).
DATABASE_PATH=../../data/app.db

# Shared bearer token (auth Mode B). Generate with: openssl rand -hex 32
# Gates every non-public API route AND is baked into the SPA bundle so the SPA
# can authenticate its own calls. scripts/init-project.sh fills this in.
AUTH_TOKEN=replace-me-openssl-rand-hex-32

NODE_ENV=development

# ─────────────────────────────────────────────────────────────────────────
# Build-time (frontend) — baked into the bundle by Vite. Must be VITE_-prefixed.
# ─────────────────────────────────────────────────────────────────────────

# Where the SPA calls the API. Empty = window.location.origin (same-origin).
# Set http://localhost:3000 for split-origin dev if you ever need it.
# Never set this to "/api" — Eden Treaty parses bare paths as hostnames (GOTCHAS G5).
VITE_API_URL=

# Must equal AUTH_TOKEN. Vite only exposes VITE_-prefixed vars to the bundle,
# hence the duplication. scripts/init-project.sh keeps them in sync.
VITE_AUTH_TOKEN=replace-me-must-match-AUTH_TOKEN

# ─────────────────────────────────────────────────────────────────────────
# Optional
# ─────────────────────────────────────────────────────────────────────────

# Expose Swagger UI at /docs. Default false. Turn OFF before exposing the app.
ENABLE_SWAGGER=true

# pino log level: trace|debug|info|warn|error. Default info.
LOG_LEVEL=info

# PORT defaults to 3000 (the single prod port). Local dev runs the API on 4000
# and Vite on 3000 (Vite proxies /api -> 4000), so you don't set PORT here.
